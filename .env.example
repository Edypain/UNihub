# Required environment variables
SECRET_KEY=your-secret-key
GEMINI_API_KEY=your-gemini-api-key
DEBUG=True

# Supabase Storage Configuration (S3-compatible API) (Optional - falls back to local if not provided)
SUPABASE_AWS_ACCESS_KEY_ID=your-supabase-s3-access-key-id
SUPABASE_AWS_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
SUPABASE_STORAGE_BUCKET_NAME=your-supabase-bucket-name
SUPABASE_S3_ENDPOINT_URL=https://<your-supabase-project-ref>.supabase.co/storage/v1/s3

